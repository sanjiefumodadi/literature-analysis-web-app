# ================= 通用系统/日志文件忽略规则 =================
# 系统缓存文件
.DS_Store
Thumbs.db
Desktop.ini

# Python 缓存与编译文件
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# 虚拟环境与依赖包
venv/
ENV/
env/
env3/
.venv/

# 运行时生成的临时/输出文件（保留白名单）
# 允许上传：*.log, *.txt, *.csv, *.html, *.json（全部保留，不删数据文件）
output.log
output/
*.tmp
*.cache

# 编辑器与系统配置
.vscode/
.idea/
*.swp
*.swo
*.bak
*.tmp

# 应用特定配置
config.ini
secrets.toml
.streamlit/

# 其他不必要的大文件/文件夹
__pycache__/
.pytest_cache/
.coverage
htmlcov/
# ================= 永久忽略所有图片文件 =================
*.png
*.jpg
*.jpeg
*.svg
*.gif
*.bmp
*.tiff
